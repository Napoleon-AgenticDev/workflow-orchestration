{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "generated": "2026-01-15",
  "repository": "https://github.com/buildmotion/buildmotion",
  "description": "Machine-readable technology stack configuration for automated tooling and AI agents",

  "primaryStack": {
    "framework": "angular",
    "frameworkVersion": "18.2.9",
    "buildSystem": "nx",
    "buildSystemVersion": "19.8.4",
    "language": "typescript",
    "languageVersion": "5.5.4",
    "runtime": "node",
    "runtimeVersion": "18.20.7",
    "packageManager": "yarn",
    "testFramework": "jest",
    "testFrameworkVersion": "29.7.0"
  },

  "frameworks": {
    "angular": {
      "version": "18.2.9",
      "packages": {
        "@angular/core": "18.2.9",
        "@angular/common": "18.2.9",
        "@angular/compiler": "18.2.9",
        "@angular/platform-browser": "18.2.9",
        "@angular/platform-browser-dynamic": "18.2.9",
        "@angular/router": "18.2.9",
        "@angular/forms": "18.2.9",
        "@angular/animations": "18.2.9"
      },
      "devPackages": {
        "@angular/cli": "~16.2.10",
        "@angular/compiler-cli": "18.2.9",
        "@angular/language-service": "18.2.9",
        "@angular-devkit/build-angular": "18.2.9"
      },
      "features": [
        "standalone-components",
        "signals",
        "inject-function",
        "reactive-forms",
        "lazy-loading",
        "animations"
      ],
      "architecture": "clean-architecture",
      "patterns": [
        "dependency-injection",
        "observable-streams",
        "signal-based-state",
        "action-command-pattern"
      ]
    },
    "nx": {
      "version": "19.8.4",
      "workspaceType": "integrated",
      "packages": {
        "nx": "19.8.4",
        "@nx/angular": "19.8.4",
        "@nx/js": "19.8.4",
        "@nx/node": "19.8.4",
        "@nx/plugin": "19.8.4",
        "@nx/jest": "19.8.4",
        "@nx/linter": "19.8.4",
        "@nx/eslint-plugin": "19.8.4",
        "@nx/workspace": "19.8.4"
      },
      "features": [
        "computation-caching",
        "affected-commands",
        "dependency-graph",
        "code-generators",
        "task-orchestration",
        "nx-cloud"
      ],
      "buildExecutors": [
        "@nx/angular:package",
        "@nx/js:tsc"
      ]
    }
  },

  "languages": {
    "typescript": {
      "version": "5.5.4",
      "target": "es2015",
      "module": "esnext",
      "lib": ["es2017", "dom"],
      "strict": false,
      "strictNullChecks": false,
      "features": {
        "decorators": true,
        "decoratorMetadata": true,
        "importHelpers": true,
        "sourceMap": true,
        "pathAliases": true
      },
      "tsconfig": "tsconfig.base.json"
    }
  },

  "runtime": {
    "node": {
      "version": "18.20.7",
      "source": ".nvmrc",
      "ltsVersion": true,
      "supportedUntil": "2025-10-31",
      "compatible": ["18.19.1+", "20.11.1+", "22.0.0+"]
    }
  },

  "packageManagers": {
    "primary": "yarn",
    "yarnVersion": "1.x",
    "lockfile": "yarn.lock",
    "alternatives": {
      "npm": {
        "supported": true,
        "lockfile": "package-lock.json"
      },
      "pnpm": {
        "supported": false
      }
    },
    "registries": {
      "public": "https://registry.npmjs.org/",
      "local": "http://localhost:4873/",
      "scope": "@buildmotion"
    }
  },

  "stateManagement": {
    "reactive": {
      "library": "rxjs",
      "version": "7.8.1",
      "usage": "http-responses, event-streams, async-operations"
    },
    "signals": {
      "library": "angular-signals",
      "version": "built-in",
      "usage": "component-state, computed-values, effects"
    },
    "stateMachine": {
      "library": "@buildmotion/state-machine",
      "usage": "workflows, wizards, multi-step-forms"
    },
    "globalStore": {
      "library": "none",
      "pattern": "service-based-state-management"
    }
  },

  "httpClient": {
    "builtIn": "angular-http-client",
    "wrappers": [
      {
        "library": "@buildmotion/http-service",
        "pattern": "observable-based",
        "features": ["logging", "error-handling", "retry-logic"]
      },
      {
        "library": "@buildmotion/http-service-signals",
        "pattern": "signal-based",
        "features": ["logging", "error-handling", "modern-api"]
      }
    ],
    "authentication": {
      "pattern": "token-interceptor",
      "storage": "localStorage",
      "configurable": true
    }
  },

  "validation": {
    "schemaValidation": {
      "library": "zod",
      "version": "^4.1.11",
      "usage": "@buildmotion/zod-rules-engine"
    },
    "rulesEngines": [
      {
        "library": "@buildmotion/rules-engine",
        "pattern": "classic-imperative",
        "usage": "business-rules, validation"
      },
      {
        "library": "@buildmotion/zod-rules-engine",
        "pattern": "reactive-schema",
        "usage": "schema-validation, type-inference"
      }
    ],
    "formValidation": {
      "library": "@buildmotion/validation",
      "integration": "angular-reactive-forms"
    }
  },

  "testing": {
    "unit": {
      "framework": "jest",
      "version": "29.7.0",
      "packages": {
        "jest": "29.7.0",
        "jest-preset-angular": "14.1.1",
        "ts-jest": "29.1.1",
        "jest-environment-jsdom": "29.7.0",
        "jest-environment-node": "29.7.0",
        "@types/jest": "29.5.14"
      },
      "config": "jest.config.ts",
      "coverage": "coverage/libs/{name}",
      "features": ["parallel-execution", "watch-mode", "snapshot-testing", "mocking"]
    },
    "e2e": {
      "framework": "none",
      "configured": false,
      "rationale": "library-focused-repository"
    },
    "mocks": [
      "LoggingServiceMock",
      "ConfigurationServiceMock"
    ]
  },

  "codeQuality": {
    "linting": {
      "tool": "eslint",
      "version": "8.57.1",
      "packages": {
        "eslint": "8.57.1",
        "@typescript-eslint/eslint-plugin": "7.18.0",
        "@typescript-eslint/parser": "7.18.0",
        "@angular-eslint/eslint-plugin": "18.4.3",
        "@angular-eslint/eslint-plugin-template": "18.4.3",
        "@angular-eslint/template-parser": "18.4.3"
      },
      "config": ".eslintrc.json",
      "rules": [
        "@nx/enforce-module-boundaries",
        "typescript-eslint",
        "angular-eslint",
        "prettier-integration"
      ]
    },
    "formatting": {
      "tool": "prettier",
      "version": "2.6.2",
      "config": ".prettierrc",
      "integration": "eslint-config-prettier"
    },
    "gitHooks": {
      "configured": false,
      "recommended": ["husky", "lint-staged", "commitlint"]
    }
  },

  "monitoring": {
    "datadog": {
      "packages": {
        "@datadog/browser-logs": "^4.13.0",
        "@datadog/browser-rum": "^4.13.0"
      },
      "features": ["real-user-monitoring", "browser-logs", "error-tracking", "session-replay"],
      "integration": "@buildmotion/logging"
    },
    "logging": {
      "library": "@buildmotion/logging",
      "severityLevels": ["Debug", "Information", "Warning", "Error", "Critical"],
      "writers": ["console", "datadog"],
      "structured": true
    },
    "errorHandling": {
      "library": "@buildmotion/error-handling",
      "apiResponseStructure": "ApiResponse<T>",
      "integration": "@buildmotion/core"
    }
  },

  "build": {
    "compilation": {
      "primary": "swc",
      "packages": {
        "@swc/core": "~1.5.7",
        "@swc-node/register": "~1.9.1",
        "@swc/helpers": "~0.5.11"
      },
      "fallback": "typescript-compiler"
    },
    "angular": {
      "packager": "ng-packagr",
      "version": "18.2.1",
      "outputFormat": "angular-package-format",
      "modules": ["esm2022", "fesm2022"]
    },
    "css": {
      "processor": "postcss",
      "version": "^8.4.5",
      "plugins": {
        "autoprefixer": "^10.4.0",
        "postcss-preset-env": "~7.5.0",
        "postcss-import": "~14.1.0",
        "postcss-url": "~10.1.3"
      }
    },
    "caching": {
      "enabled": true,
      "location": ".nx/cache",
      "inputs": ["production", "^production"],
      "outputs": ["dist/libs/{name}"]
    }
  },

  "publishing": {
    "scope": "@buildmotion",
    "libraries": 17,
    "allPublishable": true,
    "workflow": {
      "version": "yarn libs:version",
      "build": "yarn libs:build",
      "publish": "yarn libs:publish"
    },
    "localTesting": {
      "tool": "verdaccio",
      "version": "5.0.4",
      "url": "http://localhost:4873/"
    },
    "registry": {
      "production": "https://registry.npmjs.org/",
      "switchable": true
    }
  },

  "documentation": {
    "specifications": {
      "directory": ".spec-motion/",
      "count": 17,
      "format": "markdown",
      "purpose": "ai-assisted-development"
    },
    "copilotInstructions": {
      "directory": ".github/copilot/",
      "format": "markdown-with-yaml-frontmatter",
      "pattern": "applies_to-glob-patterns"
    },
    "docusaurus": {
      "app": "buildmotion-docs",
      "path": "/apps/buildmotion-docs",
      "purpose": "documentation-site"
    },
    "readmes": {
      "root": true,
      "perLibrary": true,
      "count": 18
    }
  },

  "deployment": {
    "platform": "not-specified",
    "rationale": "library-focused-repository",
    "consumerResponsibility": true,
    "commonTargets": [
      "vercel",
      "netlify",
      "aws-s3-cloudfront",
      "azure-static-web-apps",
      "docker-kubernetes"
    ]
  },

  "ci": {
    "nxCloud": {
      "enabled": true,
      "features": ["computation-caching", "distributed-task-execution"]
    },
    "recommended": {
      "platform": "github-actions",
      "checks": [
        "yarn lint",
        "yarn test",
        "yarn test:coverage",
        "yarn libs:build",
        "nx affected:test"
      ]
    },
    "configured": false
  },

  "notPresent": {
    "backend": {
      "nestjs": false,
      "express": false,
      "graphql": false,
      "orm": false
    },
    "ui": {
      "componentLibrary": false,
      "cssFramework": false
    },
    "stateManagement": {
      "ngrx": false,
      "akita": false,
      "elf": false
    },
    "e2eTesting": {
      "cypress": false,
      "playwright": false,
      "protractor": false
    },
    "containerization": {
      "docker": false,
      "kubernetes": false
    },
    "ciConfig": {
      "githubActions": false,
      "azurePipelines": false,
      "gitlabCi": false
    }
  },

  "codegenPreferences": {
    "angular": {
      "application": {
        "style": "css",
        "linter": "eslint",
        "unitTestRunner": "jest",
        "e2eTestRunner": "none"
      },
      "library": {
        "linter": "eslint",
        "unitTestRunner": "jest",
        "buildable": true,
        "publishable": true
      },
      "component": {
        "style": "css",
        "changeDetection": "OnPush",
        "standalone": true
      }
    },
    "typescript": {
      "strict": false,
      "strictNullChecks": false,
      "noImplicitAny": false
    }
  },

  "architecturePatterns": {
    "cleanArchitecture": true,
    "layers": [
      "core",
      "infrastructure",
      "presentation",
      "cross-cutting"
    ],
    "dependencyRule": "inward-flow",
    "patterns": [
      "dependency-injection",
      "repository-pattern",
      "action-command-pattern",
      "rules-engine",
      "service-base-abstraction"
    ]
  },

  "decisionMatrix": {
    "httpCalls": {
      "existingCode": "@buildmotion/http-service",
      "newCode": "@buildmotion/http-service-signals",
      "rationale": "Prefer signals for new development"
    },
    "validation": {
      "formValidation": "@buildmotion/zod-rules-engine",
      "businessRulesComplex": "@buildmotion/rules-engine",
      "simpleValidation": "@buildmotion/validation"
    },
    "businessLogic": {
      "useCases": "@buildmotion/actions",
      "validation": "@buildmotion/rules-engine | @buildmotion/zod-rules-engine"
    },
    "state": {
      "componentLocal": "angular-signals",
      "asyncStreams": "rxjs",
      "workflows": "@buildmotion/state-machine"
    },
    "crossCutting": {
      "logging": "@buildmotion/logging",
      "configuration": "@buildmotion/configuration",
      "errorHandling": "@buildmotion/error-handling"
    }
  },

  "upgradePath": {
    "angular19": {
      "status": "future",
      "action": "monitor-release",
      "considerations": ["breaking-changes", "nx-compatibility"]
    },
    "nx20": {
      "status": "future",
      "action": "align-with-angular",
      "features": ["inferred-tasks", "module-federation-v2"]
    },
    "typescript5.6": {
      "status": "future",
      "action": "test-compatibility",
      "blockers": ["angular-nx-support"]
    },
    "prettier3": {
      "status": "recommended",
      "action": "upgrade",
      "benefits": ["performance-improvements"]
    }
  },

  "qualityMetrics": {
    "versionAlignment": "excellent",
    "modernPatterns": "excellent",
    "testing": "comprehensive",
    "monitoring": "production-ready",
    "architecture": "clean",
    "developerExperience": "strong",
    "overallHealth": "8.7/10"
  },

  "recommendations": {
    "immediate": [],
    "shortTerm": [
      "Add Husky + lint-staged for git hooks",
      "Configure GitHub Actions workflows",
      "Upgrade Prettier to 3.x",
      "Add bundle size analysis"
    ],
    "longTerm": [
      "Plan Angular 19 migration",
      "Evaluate E2E testing for consumer apps",
      "Add conventional commits enforcement"
    ]
  },

  "metadata": {
    "lastUpdated": "2026-01-15",
    "reviewCadence": "quarterly",
    "owner": "Build Motion Architecture Team",
    "contact": "matt.vaughn@buildmotion.com",
    "repository": "https://github.com/buildmotion/buildmotion"
